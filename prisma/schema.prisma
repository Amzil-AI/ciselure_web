generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Image {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  filename    String
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  createdAt DateTime @default(now())
  imageId   Int
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
}
